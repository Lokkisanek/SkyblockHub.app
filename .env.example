APP_NAME=SkyblockHub
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false

# Use `reverb` for live Bazaar updates. `log` / `null` avoids running Reverb.
BROADCAST_CONNECTION=log
#
# Reverb (see https://laravel.com/docs/reverb ) — after `php artisan reverb:install`:
# REVERB_APP_ID=… REVERB_APP_KEY=… REVERB_APP_SECRET=…
# REVERB_HOST=your-public-domain.test
# REVERB_PORT=443
# REVERB_SCHEME=https
# REVERB_SERVER_HOST=0.0.0.0
# REVERB_SERVER_PORT=8080
# Vite must see the same *public* host/port the browser uses (TLS on 443), not only the internal server port:
# VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
# VITE_REVERB_HOST="${REVERB_HOST}"
# VITE_REVERB_PORT=443
# VITE_REVERB_SCHEME="${REVERB_SCHEME}"
# Nginx (or similar) must upgrade WebSocket traffic for the Pusher protocol to Reverb (paths like /app).
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
CACHE_DRIVER=file
CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Hypixel (leaderboards + profile ingest)
HYPIXEL_API_KEY=
# Paste the verification token from Hypixel Developer Dashboard (enables meta tag + /hypixel-verification.txt)
# HYPIXEL_SITE_VERIFICATION=
# If Hypixel specifies a different meta name (rare):
# HYPIXEL_VERIFICATION_META_NAME=hypixel-site-verification
# PROFILE_INGEST_ENABLED=true
# PROFILE_INGEST_MAX_PER_RUN=100
# PROFILE_INGEST_DELAY_MS=500
# PROFILE_INGEST_STALE_DAYS=7
# PROFILE_INGEST_EXTRA_UUIDS=
# PROFILE_INGEST_SITE_TOP=true
# PROFILE_INGEST_SITE_TOP_SORT=level
# PROFILE_INGEST_SITE_TOP_DIRECTION=desc
# PROFILE_INGEST_SITE_TOP_LIMIT=8000
# PROFILE_INGEST_BULK_SAFE_CAP=25000

# Social proof — “online now” (unique sessions touching the site in the last N minutes)
# SOCIAL_PROOF_ACTIVE_MINUTES=5
# SOCIAL_PROOF_PRESENCE_RETENTION_HOURS=48

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
