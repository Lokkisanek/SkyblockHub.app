APP_NAME=SkyblockHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
CACHE_DRIVER=file
CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
APP_RELEASE=

# Sentry Error Tracking (Frontend)
# Get your DSN from https://sentry.io/organizations/your-org/projects/
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=${APP_ENV}
VITE_SENTRY_RELEASE=${APP_RELEASE}
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI="${APP_URL}/auth/discord/callback"
DISCORD_ANALYTICS_WEBHOOK_URL=

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_VIP_MONTHLY=
STRIPE_PRICE_MVP_MONTHLY=
STRIPE_TRIAL_DAYS=7

FUNNEL_ANALYTICS_ENABLED=true

# Sentry Error Tracking (Backend/PHP)
# Same DSN as frontend, or separate project if preferred
SENTRY_DSN=
SENTRY_ENVIRONMENT=${APP_ENV}
SENTRY_RELEASE=${APP_RELEASE}
SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional: comma-separated SkyCrypt mirrors (will be tried in order)
# Example: SKYCRYPT_MIRRORS=https://mirror1.example/api/v2/profile,https://mirror2/api/v2/profile
SKYCRYPT_MIRRORS=

# Optional: Hypixel API key for fallback if SkyCrypt is unavailable
HYPIXEL_API_KEY=8cfc8149-ed50-4fed-8217-d2d9a9de6ef1

# Header visibility for admin-only experimental modules (0 = hidden, 1 = visible)
NAV_EXPERIMENTAL_CRAFTING_ENABLED=0
NAV_EXPERIMENTAL_DUNGEON_PARTY_ENABLED=0
NAV_EXPERIMENTAL_PORTFOLIO_ENABLED=0
NAV_EXPERIMENTAL_BIN_SNIPER_ENABLED=0
